# Generated by stackbuilder from concatenated .env.example files
# Source files: base/.env.example, step-ca/.env.example, step-ca-trust/.env.example

SYNAPSE_TZ=Europe/Moscow

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=your_password
POSTGRES_INITDB_ARGS="--encoding=UTF8 --lc-ctype=C --lc-collate=C"

SYNAPSE_PID_FILE=/data/homeserver.pid
SYNAPSE_CONFIG_PATH=/opt/synapse/homeserver.yaml
SYNAPSE_MEDIA_STORE_PATH=/data/media_store
SYNAPSE_SIGNING_KEY_PATH=/opt/key/matrix.signing.key
SYNAPSE_REPORT_STATS=no
SYNAPSE_REGISTRATION_SHARED_SECRET=aRzNUmQqX7mmM1GiJZWq0rAplgcbz35K
SYNAPSE_MACAROON_SECRET_KEY=Rtv9U3AvCPXvA8moKRDFi9BEmNJ0O38P
SYNAPSE_FORM_SECRET=Eq7nQK13iMscey9MjqCPWQieguPyPQSK
# === STEP CA CONFIGURATION ===
SYNAPSE_SERVER_NAME=matrix.local

# Virtual host domain for nginx-proxy
VIRTUAL_PORT=8008
VIRTUAL_HOST=matrix.local

# Step CA SSL certificate domain
LETSENCRYPT_HOST=matrix.local

# Email for Step CA certificate registration
LETSENCRYPT_EMAIL=john.smith@mail.com
#Step CA Trust
STEP_CA_TRUST=true
STEP_CA_TRUST_RESTART=true

REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

